---
import { getExperience } from "../data/experience.ts";
import { type Lang, t } from "../i18n/translations.ts";

interface Props { lang: Lang; }
const { lang } = Astro.props;
const tr = t(lang);
const experience = getExperience(lang);
---

<section id="experience" class="py-20 sm:py-24" aria-label={tr.experience.title}>
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <div class="reveal text-center">
      <h2 class="section-title">{tr.experience.title}</h2>
      <p class="section-subtitle">{tr.experience.subtitle}</p>
    </div>

    <div class="relative mx-auto max-w-4xl pl-10">
      <div class="timeline-line" aria-hidden="true"></div>

      {experience.map((job, index) => (
        <div class="reveal relative mb-10 last:mb-0">
          <div class={`timeline-dot ${index === 0 ? "timeline-dot--active" : ""}`} aria-hidden="true" />

          <div class="card">
            <div class="mb-3 flex flex-wrap items-start justify-between gap-2">
              <div>
                <h3 class="text-xl font-bold">{job.company}</h3>
                <p class="text-sm font-medium text-accent">{job.role}</p>
              </div>
              <div class="text-right">
                <span class="badge">{job.duration}</span>
                <p class="mt-1 text-xs text-text-dim">{job.period}</p>
              </div>
            </div>

            <p class="mb-4 text-sm text-text-muted">
              {job.industry}
              <span class="mx-2 text-border">·</span>
              <span class="font-mono text-xs text-text-dim">{job.backendFocus}</span>
            </p>

            <ul class="mb-5 space-y-1.5">
              {job.highlights.map((item) => (
                <li class="flex items-start gap-2 text-sm leading-relaxed text-text-muted">
                  <svg class="mt-1 h-3.5 w-3.5 shrink-0 text-green" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                  </svg>
                  <span>{item}</span>
                </li>
              ))}
            </ul>

            <div class="flex flex-wrap gap-1">
              {job.stack.backend.map((tech) => (
                <span class="inline-block rounded-md bg-accent/8 px-2 py-0.5 text-xs font-medium text-accent-light">{tech}</span>
              ))}
              {job.stack.frontend.map((tech) => (
                <span class="inline-block rounded-md bg-purple/8 px-2 py-0.5 text-xs font-medium text-purple">{tech}</span>
              ))}
              {job.stack.devops?.map((tech) => (
                <span class="inline-block rounded-md bg-green/8 px-2 py-0.5 text-xs font-medium text-green">{tech}</span>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
