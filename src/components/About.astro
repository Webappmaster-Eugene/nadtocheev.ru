---
import { type Lang, t } from "../i18n/translations.ts";

interface Props { lang: Lang; }
const { lang } = Astro.props;
const tr = t(lang);
---

<section id="about" class="py-20 sm:py-24" aria-label={tr.about.title}>
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <div class="reveal mb-12 text-center sm:mb-16">
      <h2 class="section-title"><span class="section-title-reveal">{tr.about.title}</span></h2>
    </div>

    <div class="reveal mx-auto max-w-3xl">
      <div class="space-y-4 text-base leading-relaxed text-text-muted sm:text-lg">
        {tr.about.paragraphs.map((p) => (
          <p set:html={p} />
        ))}
      </div>
    </div>
  </div>
</section>
