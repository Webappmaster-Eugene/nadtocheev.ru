---
import { personal } from "../data/personal.ts";
import { type Lang, t } from "../i18n/translations.ts";

interface Props { lang: Lang; }
const { lang } = Astro.props;
const tr = t(lang);
---

<section id="coding" class="py-20 sm:py-24" aria-label={tr.coding.title}>
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <div class="reveal text-center">
      <h2 class="section-title"><span class="section-title-reveal">{tr.coding.title}</span></h2>
      <p class="section-subtitle">{tr.coding.subtitle}</p>
    </div>

    <div class="reveal mx-auto max-w-3xl">
      <p class="mb-8 text-center text-base leading-relaxed text-text-muted sm:text-lg">
        {tr.coding.description}
      </p>

      <div class="grid gap-4 sm:grid-cols-2">
        <!-- LeetCode -->
        <a
          href={personal.leetcode}
          target="_blank"
          rel="noopener noreferrer"
          class="card group flex items-center gap-4 border-l-4 border-l-orange"
        >
          <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-orange/10">
            <svg class="h-6 w-6 text-orange" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M13.483 0a1.374 1.374 0 0 0-.961.438L7.116 6.226l-3.854 4.126a5.266 5.266 0 0 0-1.209 2.104 5.35 5.35 0 0 0-.125.513 5.527 5.527 0 0 0 .062 2.362 5.83 5.83 0 0 0 .349 1.017 5.938 5.938 0 0 0 1.271 1.818l4.277 4.193.039.038c2.248 2.165 5.852 2.133 8.063-.074l2.396-2.392c.54-.54.54-1.414.003-1.955a1.378 1.378 0 0 0-1.951-.003l-2.396 2.392a3.021 3.021 0 0 1-4.205.038l-.02-.019-4.276-4.193c-.652-.64-.972-1.469-.948-2.263a2.68 2.68 0 0 1 .066-.523 2.545 2.545 0 0 1 .619-1.164L9.13 8.114c1.058-1.134 3.204-1.27 4.43-.278l.257.239c.56.519 1.438.479 1.96-.09.521-.568.482-1.445-.078-1.964l-.258-.24c-2.03-1.887-5.2-1.795-7.14.206L6.956 7.37l-.006.006-2.007 2.148a5.188 5.188 0 0 0-.11.117h-.001l5.297-5.397A.374.374 0 0 1 10.39 4h3.093a1.38 1.38 0 0 0 0-2.76h-3.093c-.95 0-1.86.38-2.534 1.057L6.948 3.27l5.574-2.838A1.371 1.371 0 0 0 13.483 0zM21.5 12.41a1.38 1.38 0 0 0-1.381 1.382v3.585H9.195a1.381 1.381 0 1 0 0 2.76H21.5a1.38 1.38 0 0 0 1.381-1.38v-4.966A1.38 1.38 0 0 0 21.5 12.41z"/>
            </svg>
          </div>
          <div class="min-w-0 flex-1">
            <p class="text-lg font-bold">{tr.coding.leetcodeLabel}</p>
            <p class="text-sm text-text-muted">Numart</p>
          </div>
          <svg class="ml-auto h-5 w-5 shrink-0 text-text-dim transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
          </svg>
        </a>

        <!-- Codewars -->
        <a
          href={personal.codewars}
          target="_blank"
          rel="noopener noreferrer"
          class="card group flex items-center gap-4 border-l-4 border-l-red"
        >
          <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-red/10">
            <svg class="h-6 w-6 text-red" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M1.072.142A.991.991 0 0 0 0 1.064v21.872c0 .505.45.946.998.922h5.914a.98.98 0 0 0 .938-.922V1.064A.987.987 0 0 0 6.912.142H1.072zm8.058 0a.991.991 0 0 0-1.072.922v21.872c0 .505.45.946.998.922h5.914a.98.98 0 0 0 .938-.922V1.064a.987.987 0 0 0-.938-.922H9.13zm8.058 0a.991.991 0 0 0-1.072.922v21.872c0 .505.45.946.998.922h5.914A.98.98 0 0 0 24 22.936V1.064a.987.987 0 0 0-.938-.922H17.19z"/>
            </svg>
          </div>
          <div class="min-w-0 flex-1">
            <p class="text-lg font-bold">{tr.coding.codewarsLabel}</p>
            <p class="text-sm text-text-muted">Wepappmaster</p>
          </div>
          <svg class="ml-auto h-5 w-5 shrink-0 text-text-dim transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>
