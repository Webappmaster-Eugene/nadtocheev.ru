---
import { personal } from "../data/personal.ts";
import { type Lang, t } from "../i18n/translations.ts";

interface Props { lang: Lang; }
const { lang } = Astro.props;
const tr = t(lang);
const currentYear = new Date().getFullYear();
---

<footer class="border-t border-white/5 py-8">
  <div class="mx-auto max-w-6xl px-4 text-center sm:px-6">
    <p class="text-sm text-text-dim">
      &copy; {currentYear} {personal.name.full[lang]}. {tr.footer.rights}
    </p>
    <p class="mt-2 text-xs text-text-dim/60">
      {tr.footer.madeWith} Astro + TypeScript + Tailwind CSS
    </p>
  </div>
</footer>
