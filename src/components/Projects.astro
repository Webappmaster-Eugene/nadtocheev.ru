---
import { getProjects } from "../data/projects.ts";
import { type Lang, t } from "../i18n/translations.ts";

interface Props { lang: Lang; }
const { lang } = Astro.props;
const tr = t(lang);
const projects = getProjects(lang);
---

<section id="projects" class="py-20 sm:py-24" aria-label={tr.projects.title}>
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <div class="reveal text-center">
      <h2 class="section-title"><span class="section-title-reveal">{tr.projects.title}</span></h2>
      <p class="section-subtitle">{tr.projects.subtitle}</p>
    </div>

    <div class="stagger-children grid gap-5 md:grid-cols-3">
      {projects.map((project) => (
        <article class="card flex flex-col">
          <h3 class="mb-2 text-lg font-bold">{project.title}</h3>
          <p class="mb-1 text-xs font-semibold text-accent">{project.role}</p>
          <p class="mb-4 flex-1 text-sm leading-relaxed text-text-muted">{project.description}</p>

          <div class="mb-4 grid grid-cols-2 gap-1.5">
            {project.metrics.map((metric) => (
              <div class="rounded-lg bg-white/[0.03] px-3 py-2 text-center">
                <span class="text-xs font-medium text-text-muted">{metric}</span>
              </div>
            ))}
          </div>

          <div class="flex flex-wrap gap-1.5">
            {project.stack.map((tech) => (
              <span class="badge">{tech}</span>
            ))}
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
