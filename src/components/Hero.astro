---
import { personal, heroMetrics } from "../data/personal.ts";
import { type Lang, t } from "../i18n/translations.ts";

interface Props { lang: Lang; }
const { lang } = Astro.props;
const tr = t(lang);

const metricLabels = [tr.hero.metricsYears, tr.hero.metricsVisits, tr.hero.metricsRps, tr.hero.metricsServices];
---

<section id="hero" aria-label={tr.hero.title} class="relative overflow-hidden pt-24 pb-16 sm:pt-36 sm:pb-28">
  <!-- Background glow -->
  <div class="pointer-events-none absolute inset-0 -z-10 overflow-hidden" aria-hidden="true">
    <div class="absolute top-[-200px] left-1/2 h-[700px] w-[700px] max-w-none -translate-x-1/2 rounded-full opacity-15 blur-[120px] sm:w-[900px]"
      style="background: radial-gradient(ellipse, rgba(59,130,246,0.4) 0%, rgba(139,92,246,0.2) 40%, transparent 70%);">
    </div>
  </div>

  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <div class="flex flex-col items-center text-center">
      <!-- Status badge -->
      <div class="animate-fade-in mb-6">
        <span class="inline-flex items-center gap-2 rounded-full border border-green/20 bg-green/5 px-4 py-1.5 text-sm font-medium text-green">
          <span class="relative flex h-2 w-2">
            <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-green opacity-75"></span>
            <span class="relative inline-flex h-2 w-2 rounded-full bg-green"></span>
          </span>
          {tr.hero.badge}
        </span>
      </div>

      <!-- Name -->
      <h1 class="animate-fade-in mb-4 text-3xl leading-[1.1] font-extrabold tracking-tight sm:text-5xl lg:text-7xl" style="animation-delay:0.1s">
        {personal.name.first[lang]}{" "}
        <span class="gradient-text">{personal.name.last[lang]}</span>
      </h1>

      <!-- Role -->
      <p class="animate-slide-up mb-2 text-xl font-semibold text-text-muted sm:text-2xl" style="animation-delay:0.2s">
        {tr.hero.title}
      </p>

      <!-- Subtitle -->
      <p class="animate-slide-up mb-4 font-mono text-sm tracking-wider text-accent sm:text-base" style="animation-delay:0.25s">
        {tr.hero.subtitle}
      </p>

      <!-- Tagline -->
      <p class="animate-slide-up mb-10 max-w-2xl text-base leading-relaxed text-text-dim sm:text-lg" style="animation-delay:0.3s">
        {tr.hero.tagline}
      </p>

      <!-- CTA -->
      <div class="animate-slide-up mb-12 flex flex-wrap items-center justify-center gap-3 sm:mb-16 sm:gap-4" style="animation-delay:0.4s">
        <a href={personal.telegram} target="_blank" rel="noopener noreferrer"
          class="group inline-flex items-center gap-2 rounded-xl bg-accent px-5 py-3 text-sm font-semibold text-white shadow-lg shadow-accent/25 transition-all hover:bg-accent-dark hover:shadow-xl hover:shadow-accent/30 active:scale-[0.98] sm:gap-2.5 sm:px-7 sm:py-3.5 sm:text-base">
          <svg class="h-5 w-5 transition-transform group-hover:scale-110" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.479.33-.913.492-1.302.48-.428-.012-1.252-.242-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/>
          </svg>
          {tr.hero.ctaTelegram}
        </a>
        <a href={personal.github} target="_blank" rel="noopener noreferrer"
          class="group inline-flex items-center gap-2 rounded-xl border border-border px-5 py-3 text-sm font-semibold text-text transition-all hover:border-text/30 hover:bg-white/5 active:scale-[0.98] sm:gap-2.5 sm:px-7 sm:py-3.5 sm:text-base">
          <svg class="h-5 w-5 transition-transform group-hover:scale-110" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
          </svg>
          {tr.hero.ctaGithub}
        </a>
      </div>

      <!-- Metrics -->
      <div class="animate-slide-up grid w-full max-w-3xl grid-cols-2 gap-3 sm:grid-cols-4 sm:gap-4" style="animation-delay:0.5s">
        {heroMetrics.map((metric, i) => (
          <div class="group rounded-2xl border border-border bg-surface/50 px-4 py-5 text-center backdrop-blur-sm transition-all hover:border-accent/30 hover:bg-surface">
            <div class="text-2xl font-bold text-accent sm:text-3xl">{metric.value}</div>
            <div class="mt-1 text-xs font-medium text-text-dim sm:text-sm">{metricLabels[i]}</div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
