---
import { personal } from "../data/personal.ts";
import { type Lang, t } from "../i18n/translations.ts";

interface Props { lang: Lang; }
const { lang } = Astro.props;
const tr = t(lang);

interface ContactItem {
  label: string;
  href: string;
  username: string;
  note?: string;
  icon: string;
  color: string;
  isStroke?: boolean;
}

const contacts: ContactItem[] = [
  {
    label: "Telegram",
    href: personal.telegram,
    username: personal.telegramUsername,
    note: tr.contacts.preferredContact,
    icon: `<path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.479.33-.913.492-1.302.48-.428-.012-1.252-.242-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/>`,
    color: "text-accent hover:text-accent-light",
  },
  {
    label: tr.contacts.phone,
    href: `tel:${personal.phone.replace(/[\s()-]/g, "")}`,
    username: personal.phone,
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>`,
    color: "text-text-muted hover:text-text",
    isStroke: true,
  },
  {
    label: "Email",
    href: `mailto:${personal.email}`,
    username: personal.email,
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>`,
    color: "text-text-muted hover:text-text",
    isStroke: true,
  },
  {
    label: "GitHub",
    href: personal.github,
    username: "Webappmaster-Eugene",
    icon: `<path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>`,
    color: "text-text-muted hover:text-text",
  },
  {
    label: "Habr Career",
    href: personal.habr,
    username: "webappmaster",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>`,
    color: "text-text-muted hover:text-text",
    isStroke: true,
  },
  {
    label: lang === "ru" ? "Статьи на Хабре" : "Habr Articles",
    href: personal.habrArticles,
    username: "habr.com",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>`,
    color: "text-text-muted hover:text-text",
    isStroke: true,
  },
  {
    label: "YouTube",
    href: personal.youtube,
    username: "@webappmaster",
    icon: `<path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>`,
    color: "text-red hover:text-red",
  },
  {
    label: "webappmaster.ru",
    href: personal.websiteProjects,
    username: lang === "ru" ? "Портал проектов" : "Projects Portal",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 003 12c0-1.605.42-3.113 1.157-4.418"/>`,
    color: "text-accent hover:text-accent-light",
    isStroke: true,
  },
];
---

<section id="contacts" class="py-20 sm:py-24" aria-label={tr.contacts.title}>
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <div class="reveal text-center">
      <h2 class="section-title"><span class="section-title-reveal">{tr.contacts.title}</span></h2>
      <p class="section-subtitle">{tr.contacts.subtitle}</p>
    </div>

    <div class="stagger-children mx-auto grid max-w-2xl gap-2.5" role="list">
      {contacts.map((contact) => {
        const isExternal = contact.href.startsWith("http");
        return (
          <a
            href={contact.href}
            target={isExternal ? "_blank" : undefined}
            rel={isExternal ? "noopener noreferrer" : undefined}
            class={`card flex items-center gap-4 !p-4 ${contact.color}`}
          >
            <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-white/[0.03]">
              <svg
                class="h-5 w-5"
                viewBox="0 0 24 24"
                fill={contact.isStroke ? "none" : "currentColor"}
                stroke={contact.isStroke ? "currentColor" : "none"}
                stroke-width={contact.isStroke ? "1.5" : undefined}
                aria-hidden="true"
                set:html={contact.icon}
              />
            </div>
            <div class="min-w-0 flex-1">
              <p class="text-sm font-semibold">
                {contact.label}
                {contact.note && (
                  <span class="ml-1.5 text-xs font-normal text-text-dim">— {contact.note}</span>
                )}
              </p>
              <p class="truncate text-xs text-text-dim">{contact.username}</p>
            </div>
            <svg class="ml-auto h-4 w-4 shrink-0 text-text-dim" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        );
      })}
    </div>
  </div>
</section>
