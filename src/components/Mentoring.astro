---
import { personal } from "../data/personal.ts";
import { getMentoring } from "../data/mentoring.ts";
import { type Lang, t } from "../i18n/translations.ts";

interface Props { lang: Lang; }
const { lang } = Astro.props;
const tr = t(lang);
const mentoring = getMentoring(lang);
---

<section id="mentoring" class="py-20 sm:py-24" aria-label={tr.mentoring.title}>
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <div class="reveal text-center">
      <h2 class="section-title"><span class="section-title-reveal">{tr.mentoring.title}</span></h2>
      <p class="section-subtitle">{tr.mentoring.subtitle}</p>
    </div>

    <div class="reveal mx-auto max-w-4xl">
      <p class="mb-8 text-center text-base leading-relaxed text-text-muted sm:text-lg">
        {tr.mentoring.description}
      </p>

      <!-- Stats -->
      <div id="mentoring-stats" class="mb-10 grid grid-cols-2 gap-3 sm:grid-cols-4">
        <div class="rounded-2xl border border-border bg-surface/50 px-4 py-5 text-center">
          <div class="counter text-2xl font-bold text-accent" data-target={mentoring.stats.paidConsultations}>{mentoring.stats.paidConsultations}</div>
          <div class="mt-1 text-xs font-medium text-text-dim">{mentoring.statsLabels.paidConsultations}</div>
        </div>
        <div class="rounded-2xl border border-border bg-surface/50 px-4 py-5 text-center">
          <div class="counter text-2xl font-bold text-green" data-target={mentoring.stats.freeConsultations}>{mentoring.stats.freeConsultations}</div>
          <div class="mt-1 text-xs font-medium text-text-dim">{mentoring.statsLabels.freeConsultations}</div>
        </div>
        <div class="rounded-2xl border border-border bg-surface/50 px-4 py-5 text-center">
          <div class="counter text-2xl font-bold text-purple" data-target={mentoring.stats.teachingYears}>{mentoring.stats.teachingYears}</div>
          <div class="mt-1 text-xs font-medium text-text-dim">{mentoring.statsLabels.teachingYears}</div>
        </div>
        <div class="rounded-2xl border border-border bg-surface/50 px-4 py-5 text-center">
          <div class="counter text-2xl font-bold text-orange" data-target={mentoring.stats.platforms}>{mentoring.stats.platforms}</div>
          <div class="mt-1 text-xs font-medium text-text-dim">{mentoring.statsLabels.platforms}</div>
        </div>
      </div>

      <div class="grid gap-5 md:grid-cols-2">
        <!-- Platforms -->
        <div class="card">
          <h3 class="mb-4 text-lg font-bold">{tr.mentoring.platformsTitle}</h3>
          <div class="space-y-3">
            {mentoring.platforms.map((platform) => (
              <a
                href={platform.url}
                target="_blank"
                rel="noopener noreferrer"
                class="group flex items-center gap-3 rounded-lg p-2 transition-colors hover:bg-white/[0.03]"
              >
                <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-accent/10">
                  <svg class="h-4 w-4 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />
                  </svg>
                </div>
                <div class="min-w-0 flex-1">
                  <p class="text-sm font-semibold">{platform.name}</p>
                  <p class="text-xs text-text-dim">{platform.description}</p>
                </div>
                <svg class="h-4 w-4 shrink-0 text-text-dim transition-transform group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                </svg>
                <span class="sr-only"> {tr.a11y.opensNewTab}</span>
              </a>
            ))}
          </div>
        </div>

        <!-- Activities + Channels + Ambassador -->
        <div class="space-y-5">
          <!-- Activities -->
          <div class="card">
            <h3 class="mb-4 text-lg font-bold">{tr.mentoring.activitiesTitle}</h3>
            <ul class="space-y-2">
              {mentoring.activities.map((activity) => (
                <li class="flex items-start gap-2 text-sm leading-relaxed text-text-muted">
                  <svg class="mt-1 h-3.5 w-3.5 shrink-0 text-green" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                  </svg>
                  <span>{activity}</span>
                </li>
              ))}
            </ul>
          </div>

          <!-- Telegram Channels -->
          <div class="card">
            <h3 class="mb-2 text-sm font-bold">{tr.mentoring.channelsTitle}</h3>
            <p class="mb-3 text-xs text-text-dim">{tr.mentoring.channelsDesc}</p>
            <div class="flex flex-wrap gap-2">
              <a href={personal.telegramChannels.captainGalera} target="_blank" rel="noopener noreferrer" class="badge hover:bg-accent/15">@captain_galera<span class="sr-only"> {tr.a11y.opensNewTab}</span></a>
              <a href={personal.telegramChannels.eugeneVibecode} target="_blank" rel="noopener noreferrer" class="badge hover:bg-accent/15">@eugene_vibecode<span class="sr-only"> {tr.a11y.opensNewTab}</span></a>
            </div>
          </div>

          <!-- Ambassador -->
          <div class="card">
            <h3 class="mb-2 text-sm font-bold">{tr.mentoring.ambassadorTitle}</h3>
            <a href={personal.preoffer} target="_blank" rel="noopener noreferrer" class="group flex items-center gap-2 text-sm text-text-muted transition-colors hover:text-accent">
              <span>{tr.mentoring.ambassadorDesc}</span>
              <svg class="h-3.5 w-3.5 shrink-0 transition-transform group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
              </svg>
              <span class="sr-only"> {tr.a11y.opensNewTab}</span>
            </a>
          </div>
        </div>
      </div>

      <!-- My Website + Freelance + Startups -->
      <div class="mt-5 grid gap-4 sm:grid-cols-3">
        <!-- Website -->
        <a href={personal.websiteProjects} target="_blank" rel="noopener noreferrer" class="card group text-center" aria-label={`webappmaster.ru ${tr.a11y.opensNewTab}`}>
          <div class="mx-auto mb-2 flex h-10 w-10 items-center justify-center rounded-xl bg-accent/10">
            <svg class="h-5 w-5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 003 12c0-1.605.42-3.113 1.157-4.418" />
            </svg>
          </div>
          <p class="text-sm font-semibold">webappmaster.ru</p>
          <p class="text-xs text-text-dim">{lang === "ru" ? "Портал проектов" : "Projects Portal"}</p>
        </a>

        <!-- Freelance -->
        <div class="card text-center">
          <div class="mx-auto mb-2 flex h-10 w-10 items-center justify-center rounded-xl bg-green/10">
            <svg class="h-5 w-5 text-green" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 14.15v4.25c0 1.094-.787 2.036-1.872 2.18-2.087.277-4.216.42-6.378.42s-4.291-.143-6.378-.42c-1.085-.144-1.872-1.086-1.872-2.18v-4.25m16.5 0a2.18 2.18 0 00.75-1.661V8.706c0-1.081-.768-2.015-1.837-2.175a48.114 48.114 0 00-3.413-.387m4.5 8.006c-.194.165-.42.295-.673.38A23.978 23.978 0 0112 15.75c-2.648 0-5.195-.429-7.577-1.22a2.016 2.016 0 01-.673-.38m0 0A2.18 2.18 0 013 12.489V8.706c0-1.081.768-2.015 1.837-2.175a48.111 48.111 0 013.413-.387m7.5 0V5.25A2.25 2.25 0 0013.5 3h-3a2.25 2.25 0 00-2.25 2.25v.894m7.5 0a48.667 48.667 0 00-7.5 0M12 12.75h.008v.008H12v-.008z" />
            </svg>
          </div>
          <p class="text-sm font-semibold">{tr.mentoring.freelanceTitle}</p>
          <div class="mt-1 flex justify-center gap-2">
            <a href={personal.freelance.a24} target="_blank" rel="noopener noreferrer" class="text-xs text-text-dim hover:text-accent">a24.biz<span class="sr-only"> {tr.a11y.opensNewTab}</span></a>
            <span class="text-text-dim">·</span>
            <a href={personal.freelance.vsesdal} target="_blank" rel="noopener noreferrer" class="text-xs text-text-dim hover:text-accent">vsesdal.com<span class="sr-only"> {tr.a11y.opensNewTab}</span></a>
          </div>
        </div>

        <!-- Startups -->
        <div class="card text-center">
          <div class="mx-auto mb-2 flex h-10 w-10 items-center justify-center rounded-xl bg-purple/10">
            <svg class="h-5 w-5 text-purple" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.59 14.37a6 6 0 01-5.84 7.38v-4.8m5.84-2.58a14.98 14.98 0 006.16-12.12A14.98 14.98 0 009.631 8.41m5.96 5.96a14.926 14.926 0 01-5.841 2.58m-.119-8.54a6 6 0 00-7.381 5.84h4.8m2.581-5.84a14.927 14.927 0 00-2.58 5.84m2.699 2.7c-.103.021-.207.041-.311.06a15.09 15.09 0 01-2.448-2.448 14.9 14.9 0 01.06-.312m-2.24 2.39a4.493 4.493 0 00-1.757 4.306 4.493 4.493 0 004.306-1.758M16.5 9a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0z" />
            </svg>
          </div>
          <p class="text-sm font-semibold">{tr.startups.title}</p>
          <div class="mt-1 flex flex-wrap justify-center gap-1.5">
            <a href={personal.startups.adminHouse} target="_blank" rel="noopener noreferrer" class="badge text-xs hover:bg-purple/15">admin-house<span class="sr-only"> {tr.a11y.opensNewTab}</span></a>
            <a href={personal.startups.mskFlatParser} target="_blank" rel="noopener noreferrer" class="badge text-xs hover:bg-purple/15">msk-flat-parser<span class="sr-only"> {tr.a11y.opensNewTab}</span></a>
            <a href={personal.startups.calendarClown} target="_blank" rel="noopener noreferrer" class="badge text-xs hover:bg-purple/15">calendar-clown<span class="sr-only"> {tr.a11y.opensNewTab}</span></a>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Mentoring animated counters -->
  <script is:inline>
    (function () {
      if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;
      var counters = document.querySelectorAll("#mentoring-stats .counter");
      if (!counters.length) return;

      function easeOutCubic(t) { return 1 - Math.pow(1 - t, 3); }

      function animateCounter(el) {
        var raw = el.getAttribute("data-target") || "";
        var suffix = "";
        var numStr = raw;
        if (raw.endsWith("K+")) { suffix = "K+"; numStr = raw.slice(0, -2); }
        else if (raw.endsWith("+")) { suffix = "+"; numStr = raw.slice(0, -1); }
        var target = parseInt(numStr, 10);
        if (isNaN(target)) return;
        var duration = 1500;
        var start = performance.now();
        el.textContent = "0" + suffix;
        function step(now) {
          var elapsed = now - start;
          var progress = Math.min(elapsed / duration, 1);
          var value = Math.round(easeOutCubic(progress) * target);
          el.textContent = value + suffix;
          if (progress < 1) requestAnimationFrame(step);
        }
        requestAnimationFrame(step);
      }

      var observer = new IntersectionObserver(function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) {
            animateCounter(entry.target);
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.3 });

      counters.forEach(function (el) { observer.observe(el); });
    })();
  </script>
</section>
