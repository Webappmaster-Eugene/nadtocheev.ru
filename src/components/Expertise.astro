---
import { getExpertise } from "../data/skills.ts";
import { type Lang, t } from "../i18n/translations.ts";

interface Props { lang: Lang; }
const { lang } = Astro.props;
const tr = t(lang);
const expertise = getExpertise(lang);

const icons: Record<string, string> = {
  server: `<path stroke-linecap="round" stroke-linejoin="round" d="M5 12H3a2 2 0 01-2-2V6a2 2 0 012-2h18a2 2 0 012 2v4a2 2 0 01-2 2h-2M5 12H3a2 2 0 00-2 2v4a2 2 0 002 2h18a2 2 0 002-2v-4a2 2 0 00-2-2h-2M5 12h14M7 8h.01M7 16h.01"/>`,
  cloud: `<path stroke-linecap="round" stroke-linejoin="round" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z"/>`,
  layout: `<path stroke-linecap="round" stroke-linejoin="round" d="M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5zM4 13a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1-1v-6zM16 13a1 1 0 011-1h2a1 1 0 011 1v6a1 1 0 01-1 1h-2a1 1 0 01-1-1v-6z"/>`,
  bot: `<path stroke-linecap="round" stroke-linejoin="round" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"/>`,
  brain: `<path stroke-linecap="round" stroke-linejoin="round" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>`,
};
const accentColors = ["border-l-accent", "border-l-green", "border-l-orange", "border-l-red", "border-l-purple"];
---

<section id="expertise" class="py-20 sm:py-24" aria-label={tr.expertise.title}>
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <div class="reveal text-center">
      <h2 class="section-title"><span class="section-title-reveal">{tr.expertise.title}</span></h2>
      <p class="section-subtitle">{tr.expertise.subtitle}</p>
    </div>

    <div class="stagger-children grid gap-5 sm:grid-cols-2">
      {expertise.map((cat, i) => (
        <div class={`card border-l-4 ${accentColors[i]}`}>
          <div class="mb-4 flex items-center gap-3">
            <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-accent/10">
              <svg class="h-5 w-5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true" set:html={icons[cat.icon]} />
            </div>
            <h3 class="text-lg font-bold">{cat.title}</h3>
          </div>
          <p class="mb-4 text-sm leading-relaxed text-text-muted">{cat.description}</p>
          <div class="flex flex-wrap gap-1.5">
            {cat.skills.map((skill) => (
              <span class="badge">{skill}</span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
