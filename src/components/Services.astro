---
import { personal } from "../data/personal.ts";
import { getServices } from "../data/services.ts";
import { type Lang, t } from "../i18n/translations.ts";

interface Props { lang: Lang; }
const { lang } = Astro.props;
const tr = t(lang);
const services = getServices(lang);

const accentClasses: Record<string, { bg: string; text: string; border: string; ring: string }> = {
  accent: { bg: "bg-accent/10", text: "text-accent", border: "hover:border-accent/40", ring: "shadow-accent/20" },
  purple: { bg: "bg-purple/10", text: "text-purple", border: "hover:border-purple/40", ring: "shadow-purple/20" },
  green:  { bg: "bg-green/10",  text: "text-green",  border: "hover:border-green/40",  ring: "shadow-green/20"  },
  orange: { bg: "bg-orange/10", text: "text-orange", border: "hover:border-orange/40", ring: "shadow-orange/20" },
};
---

<section id="services" class="py-20 sm:py-24" aria-label={tr.services.title}>
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <div class="reveal text-center">
      <h2 class="section-title"><span class="section-title-reveal">{tr.services.title}</span></h2>
      <p class="section-subtitle">{tr.services.subtitle}</p>
    </div>

    <div class="reveal mx-auto max-w-4xl">
      <p class="mb-10 text-center text-base leading-relaxed text-text-muted sm:text-lg">
        {tr.services.description}
      </p>

      <div class="grid gap-5 md:grid-cols-2">
        {services.items.map((service) => {
          const a = accentClasses[service.accent] ?? accentClasses.accent;
          return (
            <div class={`card flex flex-col transition-all ${a.border} hover:shadow-lg hover:${a.ring}`}>
              <!-- Header: icon + name -->
              <div class="mb-4 flex items-start gap-3">
                <div class={`flex h-11 w-11 shrink-0 items-center justify-center rounded-xl ${a.bg}`}>
                  {service.icon === "consult" ? (
                    <svg class={`h-5 w-5 ${a.text}`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 4v-4z" />
                    </svg>
                  ) : (
                    <svg class={`h-5 w-5 ${a.text}`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                      <path stroke-linecap="round" stroke-linejoin="round" d="M20 8v3m-1.5-1.5h3" />
                    </svg>
                  )}
                </div>
                <div class="min-w-0 flex-1">
                  <h3 class="text-lg font-bold leading-tight sm:text-xl">{service.name}</h3>
                  <p class="mt-1 text-xs font-medium text-text-dim">{service.duration}</p>
                </div>
              </div>

              <!-- Price -->
              <div class="mb-4 flex items-baseline gap-2">
                <span class={`text-3xl font-extrabold ${a.text} sm:text-4xl`}>{service.price}</span>
                <span class="text-sm text-text-dim">/ {service.duration}</span>
              </div>

              <!-- Description -->
              <p class="mb-5 text-sm leading-relaxed text-text-muted">
                {service.description}
              </p>

              <!-- Includes -->
              <div class="mb-6 flex-1">
                <p class="mb-2 text-xs font-semibold uppercase tracking-wider text-text-dim">
                  {tr.services.includesLabel}
                </p>
                <ul class="space-y-2">
                  {service.includes.map((line) => (
                    <li class="flex items-start gap-2 text-sm leading-relaxed text-text-muted">
                      <svg class={`mt-1 h-3.5 w-3.5 shrink-0 ${a.text}`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                      </svg>
                      <span>{line}</span>
                    </li>
                  ))}
                </ul>
              </div>

              <!-- CTA -->
              <a
                href={personal.telegram}
                target="_blank"
                rel="noopener noreferrer"
                class={`mt-auto inline-flex items-center justify-center gap-2 rounded-xl ${a.bg} px-5 py-3 text-sm font-semibold ${a.text} transition-all hover:brightness-110 active:scale-[0.98]`}
              >
                <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.479.33-.913.492-1.302.48-.428-.012-1.252-.242-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/>
                </svg>
                {services.ctaLabel}
                <span class="sr-only"> {tr.a11y.opensNewTab}</span>
              </a>
            </div>
          );
        })}
      </div>

      <p class="mt-6 text-center text-xs text-text-dim sm:text-sm">
        {tr.services.note}
      </p>
    </div>
  </div>
</section>
