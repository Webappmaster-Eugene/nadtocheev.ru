---
/**
 * Base layout — полное SEO (meta, OG, hreflang, JSON-LD Person),
 * шрифты, анимации, двуязычная поддержка.
 */
import "../styles/global.css";
import { personal } from "../data/personal.ts";
import { type Lang, t } from "../i18n/translations.ts";

interface Props {
  lang: Lang;
  title?: string;
  description?: string;
  ogImage?: string;
}

const { lang } = Astro.props;
const tr = t(lang);

const title = Astro.props.title ?? tr.meta.title;
const description = Astro.props.description ?? tr.meta.description;
const ogImage = Astro.props.ogImage ?? "/og-image.png";

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ruURL = new URL("/", Astro.site);
const enURL = new URL("/en/", Astro.site);

/** JSON-LD: Person + WebSite — структурированные данные для SEO и LLM */
/** FAQ для LLM и SEO */
const faqItems = lang === "ru"
  ? [
      { q: "Чем занимается Евгений Надточеев?", a: "Fullstack-разработчик с 5 годами опыта. Специализируется на backend (Node.js, Go), DevOps (Kubernetes, Docker) и AI/LLM интеграциях. Работает в сфере highload-систем в финтехе и аналитике недвижимости." },
      { q: "Какой технологический стек?", a: "Backend: Node.js, Go, NestJS, PostgreSQL, Redis, Kafka, gRPC. DevOps: Kubernetes, Docker, CI/CD, OpenTelemetry. Frontend: React, Vue, Next.js, Astro, TypeScript, Tailwind CSS." },
      { q: "Можно ли нанять Евгения как ментора?", a: "Да, Евгений проводит мок-собеседования, карьерные консультации и менторство для fullstack-разработчиков. Доступен на Solvery, GetMentor, EasyOffer и через Telegram." },
      { q: "Как связаться с Евгением?", a: "Предпочитаемый способ — Telegram: @eugene_nadtocheev. Также доступен по email: johnn.hotmail@mail.ru и телефону: +7 (920) 080-87-00." },
      { q: "В каких отраслях работал Евгений?", a: "Финтех (платёжные системы, криптовалюты, биллинг), аналитика недвижимости (топ-1 платформа в РФ с 200K+ посещений/сутки и 2000 rps), маркетинг и реклама, системная интеграция и IT-консалтинг." },
      { q: "Работает ли Евгений с AI и LLM?", a: "Да, активно. Строит RAG-пайплайны, интегрирует LLM в рабочие процессы, ежедневно использует Claude Code и Cursor. Создал Telegram-бота с голосовым управлением Google Calendar через AI." },
      { q: "Какое образование у Евгения?", a: "Академия ФСБ России (2019). Специальность: автоматизированные системы управления, автоматизированная обработка информации и управление." },
      { q: "Создавал ли Евгений свои стартапы?", a: "Да, создатель двух собственных продуктов: СПИН (podbor-minuta.ru) — сервис мониторинга цен на новостройки Москвы с уведомлениями о скидках застройщиков (ПИК, Самолёт, Гранель, Level, Эталон) в Telegram; и SMETAS (alibaba.hhos.ru) — SaaS-платформа для составления строительных смет с базой материалов и командной работой." },
      { q: "В каком формате Евгений работает?", a: "Удалённо из Москвы. Доступен для клиентов по всей России и странам СНГ. Менторство — для русскоязычных разработчиков по всему миру." },
    ]
  : [
      { q: "What does Evgeny Nadtocheev do?", a: "Fullstack Developer with 5 years of experience. Specializes in backend (Node.js, Go), DevOps (Kubernetes, Docker), and AI/LLM integrations. Works on high-load systems in fintech and real estate analytics." },
      { q: "What is his tech stack?", a: "Backend: Node.js, Go, NestJS, PostgreSQL, Redis, Kafka, gRPC. DevOps: Kubernetes, Docker, CI/CD, OpenTelemetry. Frontend: React, Vue, Next.js, Astro, TypeScript, Tailwind CSS." },
      { q: "Can I hire Evgeny as a mentor?", a: "Yes, Evgeny conducts mock interviews, career consultations, and mentoring for fullstack developers. Available on Solvery, GetMentor, EasyOffer, and via Telegram." },
      { q: "How to contact Evgeny?", a: "Preferred method — Telegram: @eugene_nadtocheev. Also available via email: johnn.hotmail@mail.ru and phone: +7 (920) 080-87-00." },
      { q: "What industries has he worked in?", a: "Fintech (payment systems, cryptocurrency, billing), real estate analytics (#1 platform in Russia with 200K+ daily visits and 2,000 rps), marketing & advertising, system integration and IT consulting." },
      { q: "Does he work with AI and LLMs?", a: "Yes, actively. He builds RAG pipelines, integrates LLMs into workflows, uses Claude Code and Cursor daily. He built a Telegram bot with voice-controlled Google Calendar management via AI." },
      { q: "What is his education?", a: "Academy of the Federal Security Service of Russia (2019). Specialty: Automated Control Systems, Automated Information Processing and Control Systems." },
      { q: "Has Evgeny founded any startups?", a: "Yes, he is the founder of two products of his own: SPIN (podbor-minuta.ru) — a Moscow new-build price tracker with Telegram alerts on discounts from major developers (PIK, Samolet, Granel, Level, Etalon); and SMETAS (alibaba.hhos.ru) — a SaaS platform for construction estimates with a shared materials database and team collaboration." },
      { q: "What is his work format?", a: "Remote from Moscow. Available for clients across Russia and CIS countries. Mentoring available worldwide for Russian-speaking developers." },
    ];

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Person",
      "@id": `${personal.website}/#person`,
      name: personal.name.full[lang],
      alternateName: lang === "ru" ? personal.name.full.en : personal.name.full.ru,
      givenName: personal.name.first[lang],
      familyName: personal.name.last[lang],
      jobTitle: lang === "ru"
        ? "Fullstack-разработчик (Node.js, Go, React)"
        : "Fullstack Developer (Node.js, Go, React)",
      description: description,
      url: personal.website,
      email: personal.email,
      telephone: personal.phone,
      image: `${personal.website}/photo.jpg`,
      sameAs: [
        personal.github,
        personal.habr,
        personal.telegram,
        personal.habrArticles,
        personal.websiteProjects,
        personal.leetcode,
        personal.codewars,
        personal.telegramChannels.captainGalera,
        personal.telegramChannels.eugeneVibecode,
        personal.mentoring.solvery,
        personal.mentoring.getmentor,
      ],
      knowsAbout: [
        "Node.js", "Go", "TypeScript", "React", "Vue.js", "NestJS",
        "Kubernetes", "Docker", "PostgreSQL", "Redis", "Apache Kafka",
        "Microservices", "CI/CD", "System Design", "AI/LLM", "RAG",
        "gRPC", "Event-Driven Architecture", "DevOps",
        "Telegram Bots", "Telegram Mini App", "React Native", "Electron",
        "Mentoring", "Technical Education",
      ],
      knowsLanguage: [
        { "@type": "Language", name: "Russian", alternateName: "ru" },
        { "@type": "Language", name: "English", alternateName: "en", proficiencyLevel: "B1" },
      ],
      address: {
        "@type": "PostalAddress",
        addressLocality: lang === "ru" ? "Москва" : "Moscow",
        addressCountry: "RU",
      },
      nationality: { "@type": "Country", name: lang === "ru" ? "Россия" : "Russia" },
    },
    {
      "@type": "WebSite",
      "@id": `${personal.website}/#website`,
      url: personal.website,
      name: title,
      description: description,
      inLanguage: [tr.meta.htmlLang],
      publisher: { "@id": `${personal.website}/#person` },
    },
    {
      "@type": "ProfilePage",
      "@id": canonicalURL.href,
      url: canonicalURL.href,
      name: title,
      description: description,
      inLanguage: tr.meta.htmlLang,
      isPartOf: { "@id": `${personal.website}/#website` },
      about: { "@id": `${personal.website}/#person` },
      mainEntity: { "@id": `${personal.website}/#person` },
      speakable: {
        "@type": "SpeakableSpecification",
        cssSelector: ["#hero", "#about", "#contacts"],
      },
    },
    {
      "@type": "BreadcrumbList",
      "@id": `${canonicalURL.href}#breadcrumb`,
      itemListElement: [
        {
          "@type": "ListItem",
          position: 1,
          name: lang === "ru" ? "Главная" : "Home",
          item: lang === "ru" ? personal.website : `${personal.website}/en/`,
        },
      ],
    },
    {
      "@type": "Organization",
      "@id": `${personal.website}/#organization`,
      name: personal.name.full[lang],
      url: personal.website,
      logo: `${personal.website}/favicon-512.png`,
      founder: { "@id": `${personal.website}/#person` },
      sameAs: [personal.github, personal.telegram],
    },
    {
      "@type": "Service",
      "@id": `${personal.website}/#mentoring`,
      name: lang === "ru"
        ? "Менторство и карьерные консультации для разработчиков"
        : "Mentoring & Career Consulting for Developers",
      description: lang === "ru"
        ? "Мок-собеседования, карьерные консультации, менторство для fullstack-разработчиков по авторской системе"
        : "Mock interviews, career consulting, mentoring for fullstack developers with custom methodology",
      provider: { "@id": `${personal.website}/#person` },
      areaServed: [
        { "@type": "Country", name: "Russia" },
        { "@type": "Country", name: "CIS" },
      ],
      serviceType: lang === "ru" ? "Менторство в IT" : "IT Mentoring",
    },
    {
      "@type": "FAQPage",
      "@id": `${canonicalURL.href}#faq`,
      mainEntity: faqItems.map((item) => ({
        "@type": "Question",
        name: item.q,
        acceptedAnswer: { "@type": "Answer", text: item.a },
      })),
    },
    {
      "@type": "SoftwareApplication",
      "@id": `${personal.website}/#startup-spin`,
      name: "СПИН",
      applicationCategory: "BusinessApplication",
      operatingSystem: "Web",
      description: lang === "ru"
        ? "Сервис мониторинга цен на новостройки Москвы с уведомлениями о скидках застройщиков в Telegram"
        : "Moscow new-build price tracker with Telegram alerts on discounts from major developers",
      url: personal.startups.spin,
      author: { "@id": `${personal.website}/#person` },
    },
    {
      "@type": "SoftwareApplication",
      "@id": `${personal.website}/#startup-smetas`,
      name: "SMETAS",
      applicationCategory: "BusinessApplication",
      operatingSystem: "Web",
      description: lang === "ru"
        ? "SaaS-платформа для составления строительных смет с базой материалов и командной работой"
        : "SaaS platform for construction estimates with shared materials database and team collaboration",
      url: personal.startups.smetas,
      author: { "@id": `${personal.website}/#person` },
    },
    {
      "@type": "ItemList",
      "@id": `${personal.website}/#techstack`,
      name: lang === "ru" ? "Технологический стек" : "Tech Stack",
      numberOfItems: 9,
      itemListElement: [
        { "@type": "ListItem", position: 1, name: "Node.js" },
        { "@type": "ListItem", position: 2, name: "Go" },
        { "@type": "ListItem", position: 3, name: "TypeScript" },
        { "@type": "ListItem", position: 4, name: "React" },
        { "@type": "ListItem", position: 5, name: "Kubernetes" },
        { "@type": "ListItem", position: 6, name: "Docker" },
        { "@type": "ListItem", position: 7, name: "PostgreSQL" },
        { "@type": "ListItem", position: 8, name: "NestJS" },
        { "@type": "ListItem", position: 9, name: "Kafka" },
      ],
    },
  ],
};
---

<!doctype html>
<html lang={tr.meta.htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- SEO Meta -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content={personal.name.full[lang]} />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1" />
    <meta name="keywords" content={lang === "ru"
      ? "fullstack разработчик, backend разработчик, Node.js, Go, React, DevOps, Kubernetes, Docker, микросервисы, менторство, AI, LLM, Москва, highload, NestJS, TypeScript, портфолио"
      : "fullstack developer, backend developer, Node.js, Go, React, DevOps, Kubernetes, Docker, microservices, mentoring, AI, LLM, Moscow, high-load, NestJS, TypeScript, portfolio"} />
    <link rel="canonical" href={canonicalURL} />

    <!-- hreflang — для мультиязычного SEO -->
    <link rel="alternate" hreflang="ru" href={ruURL} />
    <link rel="alternate" hreflang="en" href={enURL} />
    <link rel="alternate" hreflang="x-default" href={ruURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="profile" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.site)} />
    <meta property="og:image:alt" content={lang === "ru"
      ? `${personal.name.full.ru} — Fullstack-разработчик`
      : `${personal.name.full.en} — Fullstack Developer`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content={tr.meta.ogLocale} />
    <meta property="og:locale:alternate" content={lang === "ru" ? "en_US" : "ru_RU"} />
    <meta property="og:site_name" content={personal.name.full[lang]} />
    <meta property="profile:first_name" content={personal.name.first[lang]} />
    <meta property="profile:last_name" content={personal.name.last[lang]} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site)} />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <!-- Theme color -->
    <meta name="theme-color" content="#0a0a0b" id="meta-theme-color" />
    <meta name="color-scheme" content="dark light" />

    <!-- Prevent flash of wrong theme -->
    <script is:inline>
      (function() {
        var theme = localStorage.getItem("theme") || "dark";
        if (theme === "light") {
          document.documentElement.classList.add("light");
          var m = document.getElementById("meta-theme-color");
          if (m) m.setAttribute("content", "#f8fafc");
        }
      })();
    </script>

    <!-- IndieWeb: rel="me" для связывания профилей -->
    <link rel="me" href={personal.telegram} />
    <link rel="me" href={personal.github} />

    <!-- Favicons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="msapplication-TileColor" content="#0a0a0b" />

    <!-- DNS prefetch + Preconnect -->
    <link rel="dns-prefetch" href="https://fonts.googleapis.com" />
    <link rel="dns-prefetch" href="https://fonts.gstatic.com" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <!-- Fonts: Inter + JetBrains Mono (non-blocking) -->
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap"
      onload="this.onload=null;this.rel='stylesheet'"
    />
    <noscript>
      <link
        href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap"
        rel="stylesheet"
      />
    </noscript>

    <!-- GEO-оптимизация для нейросетей и поисковиков -->
    <meta name="geo.region" content="RU-MOW" />
    <meta name="geo.placename" content={lang === "ru" ? "Москва" : "Moscow"} />
    <meta name="geo.position" content="55.7558;37.6173" />
    <meta name="ICBM" content="55.7558, 37.6173" />

    <!-- Yandex / Google verification — вставьте реальные ID -->
    <!-- <meta name="yandex-verification" content="XXXXXX" /> -->
    <!-- <meta name="google-site-verification" content="XXXXXX" /> -->
  </head>

  <body class="min-h-screen bg-bg text-text antialiased">
    <a href="#main-content" class="skip-link">{tr.a11y.skipToContent}</a>
    <div id="scroll-progress" aria-hidden="true"></div>
    <slot />

    <!-- Scroll-triggered reveal animations -->
    <script is:inline>
      document.addEventListener("DOMContentLoaded", function () {
        var targets = document.querySelectorAll(".reveal, .stagger-children");
        if (!targets.length) return;
        var observer = new IntersectionObserver(
          function (entries) {
            entries.forEach(function (entry) {
              if (entry.isIntersecting) {
                entry.target.classList.add("visible");
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.1, rootMargin: "0px 0px -60px 0px" }
        );
        targets.forEach(function (el) { observer.observe(el); });
      });
    </script>

    <!-- Scroll progress bar -->
    <script is:inline>
      (function () {
        if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;
        var bar = document.getElementById("scroll-progress");
        if (!bar) return;
        window.addEventListener("scroll", function () {
          var scrollTop = window.scrollY;
          var docHeight = document.documentElement.scrollHeight - window.innerHeight;
          if (docHeight > 0) {
            bar.style.width = (scrollTop / docHeight * 100) + "%";
          }
        }, { passive: true });
      })();
    </script>

    <!-- Button ripple effect -->
    <script is:inline>
      (function () {
        if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;
        document.addEventListener("click", function (e) {
          var btn = e.target.closest(".btn-ripple");
          if (!btn) return;
          var rect = btn.getBoundingClientRect();
          var ripple = document.createElement("span");
          ripple.className = "ripple";
          ripple.style.left = (e.clientX - rect.left) + "px";
          ripple.style.top = (e.clientY - rect.top) + "px";
          btn.appendChild(ripple);
          ripple.addEventListener("animationend", function () {
            ripple.remove();
          });
        });
      })();
    </script>

    <!-- Section anchor links + back-to-top -->
    <button id="back-to-top" class="back-to-top" type="button" aria-label={lang === "ru" ? "Наверх" : "Back to top"} title={lang === "ru" ? "Наверх" : "Back to top"}>
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M12 19V5" />
        <path d="M5 12l7-7 7 7" />
      </svg>
    </button>

    <script is:inline define:vars={{ anchorAria: lang === "ru" ? "Скопировать ссылку на раздел" : "Copy link to section" }}>
      document.addEventListener("DOMContentLoaded", function () {
        /* Section anchor # buttons */
        document.querySelectorAll("section[id]").forEach(function (section) {
          var id = section.id;
          if (!id || id === "hero") return;
          var h2 = section.querySelector("h2.section-title");
          if (!h2 || h2.querySelector(".section-anchor")) return;
          var a = document.createElement("a");
          a.href = "#" + id;
          a.className = "section-anchor";
          a.textContent = "#";
          a.setAttribute("aria-label", anchorAria + ": " + h2.textContent.trim());
          a.addEventListener("click", function (e) {
            if (navigator.clipboard && window.location && window.location.href) {
              var url = window.location.origin + window.location.pathname + "#" + id;
              navigator.clipboard.writeText(url).then(function () {
                a.classList.add("copied");
                setTimeout(function () { a.classList.remove("copied"); }, 1500);
              }).catch(function () {});
            }
          });
          h2.appendChild(a);
        });

        /* Back-to-top button */
        var btn = document.getElementById("back-to-top");
        if (!btn) return;
        var threshold = 600;
        var update = function () {
          if (window.scrollY > threshold) btn.classList.add("visible");
          else btn.classList.remove("visible");
        };
        window.addEventListener("scroll", update, { passive: true });
        update();
        btn.addEventListener("click", function () {
          window.scrollTo({ top: 0, behavior: "smooth" });
        });
      });
    </script>
  </body>
</html>
