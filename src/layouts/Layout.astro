---
/**
 * Base layout — полное SEO (meta, OG, hreflang, JSON-LD Person),
 * шрифты, анимации, двуязычная поддержка.
 */
import "../styles/global.css";
import { personal } from "../data/personal.ts";
import { type Lang, t } from "../i18n/translations.ts";

interface Props {
  lang: Lang;
  title?: string;
  description?: string;
  ogImage?: string;
}

const { lang } = Astro.props;
const tr = t(lang);

const title = Astro.props.title ?? tr.meta.title;
const description = Astro.props.description ?? tr.meta.description;
const ogImage = Astro.props.ogImage ?? "/og-image.png";

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ruURL = new URL("/", Astro.site);
const enURL = new URL("/en/", Astro.site);

/** JSON-LD: Person + WebSite — структурированные данные для SEO и LLM */
/** FAQ для LLM и SEO */
const faqItems = lang === "ru"
  ? [
      { q: "Чем занимается Евгений Надточеев?", a: "Fullstack-разработчик с 5+ годами опыта. Специализируется на backend (Node.js, Go), DevOps (Kubernetes, Docker) и AI/LLM интеграциях. Работает в сфере highload-систем в финтехе и аналитике недвижимости." },
      { q: "Какой технологический стек?", a: "Backend: Node.js, Go, NestJS, PostgreSQL, Redis, Kafka, gRPC. DevOps: Kubernetes, Docker, CI/CD, OpenTelemetry. Frontend: React, Vue, Next.js, Astro, TypeScript, Tailwind CSS." },
      { q: "Можно ли нанять Евгения как ментора?", a: "Да, Евгений проводит мок-собеседования, карьерные консультации и менторство для fullstack-разработчиков. Доступен на Solvery, GetMentor, EasyOffer и через Telegram." },
      { q: "Как связаться с Евгением?", a: "Предпочитаемый способ — Telegram: @eugene_nadtocheev. Также доступен по email: johnn.hotmail@mail.ru и телефону: +7 (920) 080-87-00." },
    ]
  : [
      { q: "What does Evgeny Nadtocheev do?", a: "Fullstack Developer with 5+ years of experience. Specializes in backend (Node.js, Go), DevOps (Kubernetes, Docker), and AI/LLM integrations. Works on high-load systems in fintech and real estate analytics." },
      { q: "What is his tech stack?", a: "Backend: Node.js, Go, NestJS, PostgreSQL, Redis, Kafka, gRPC. DevOps: Kubernetes, Docker, CI/CD, OpenTelemetry. Frontend: React, Vue, Next.js, Astro, TypeScript, Tailwind CSS." },
      { q: "Can I hire Evgeny as a mentor?", a: "Yes, Evgeny conducts mock interviews, career consultations, and mentoring for fullstack developers. Available on Solvery, GetMentor, EasyOffer, and via Telegram." },
      { q: "How to contact Evgeny?", a: "Preferred method — Telegram: @eugene_nadtocheev. Also available via email: johnn.hotmail@mail.ru and phone: +7 (920) 080-87-00." },
    ];

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Person",
      "@id": `${personal.website}/#person`,
      name: personal.name.full[lang],
      alternateName: lang === "ru" ? personal.name.full.en : personal.name.full.ru,
      givenName: personal.name.first[lang],
      familyName: personal.name.last[lang],
      jobTitle: lang === "ru"
        ? "Fullstack-разработчик (Node.js, Go, React)"
        : "Fullstack Developer (Node.js, Go, React)",
      description: description,
      url: personal.website,
      email: personal.email,
      telephone: personal.phone,
      image: `${personal.website}/photo.jpg`,
      sameAs: [
        personal.github,
        personal.habr,
        personal.telegram,
        personal.youtube,
        personal.habrArticles,
        personal.websiteProjects,
        personal.leetcode,
        personal.codewars,
        personal.telegramChannels.captainGalera,
        personal.telegramChannels.eugeneVibecode,
        personal.mentoring.solvery,
        personal.mentoring.getmentor,
      ],
      knowsAbout: [
        "Node.js", "Go", "TypeScript", "React", "Vue.js", "NestJS",
        "Kubernetes", "Docker", "PostgreSQL", "Redis", "Apache Kafka",
        "Microservices", "CI/CD", "System Design", "AI/LLM", "RAG",
        "gRPC", "Event-Driven Architecture", "DevOps",
        "Telegram Bots", "Telegram Mini App", "React Native", "Electron",
        "Mentoring", "Technical Education",
      ],
      knowsLanguage: [
        { "@type": "Language", name: "Russian", alternateName: "ru" },
        { "@type": "Language", name: "English", alternateName: "en", proficiencyLevel: "B1" },
      ],
      address: {
        "@type": "PostalAddress",
        addressLocality: lang === "ru" ? "Москва" : "Moscow",
        addressCountry: "RU",
      },
      nationality: { "@type": "Country", name: lang === "ru" ? "Россия" : "Russia" },
    },
    {
      "@type": "WebSite",
      "@id": `${personal.website}/#website`,
      url: personal.website,
      name: title,
      description: description,
      inLanguage: [tr.meta.htmlLang],
      publisher: { "@id": `${personal.website}/#person` },
    },
    {
      "@type": "ProfilePage",
      "@id": canonicalURL.href,
      url: canonicalURL.href,
      name: title,
      description: description,
      inLanguage: tr.meta.htmlLang,
      isPartOf: { "@id": `${personal.website}/#website` },
      about: { "@id": `${personal.website}/#person` },
      mainEntity: { "@id": `${personal.website}/#person` },
    },
    {
      "@type": "Service",
      "@id": `${personal.website}/#mentoring`,
      name: lang === "ru"
        ? "Менторство и карьерные консультации для разработчиков"
        : "Mentoring & Career Consulting for Developers",
      description: lang === "ru"
        ? "Мок-собеседования, карьерные консультации, менторство для fullstack-разработчиков по авторской системе"
        : "Mock interviews, career consulting, mentoring for fullstack developers with custom methodology",
      provider: { "@id": `${personal.website}/#person` },
      areaServed: [
        { "@type": "Country", name: "Russia" },
        { "@type": "Country", name: "CIS" },
      ],
      serviceType: lang === "ru" ? "Менторство в IT" : "IT Mentoring",
    },
    {
      "@type": "FAQPage",
      "@id": `${canonicalURL.href}#faq`,
      mainEntity: faqItems.map((item) => ({
        "@type": "Question",
        name: item.q,
        acceptedAnswer: { "@type": "Answer", text: item.a },
      })),
    },
    {
      "@type": "CreativeWork",
      "@id": `${personal.website}/#startup-admin-house`,
      name: "Admin House",
      description: lang === "ru"
        ? "Платформа для архитектурного проектирования"
        : "Architectural design platform",
      url: personal.startups.adminHouse,
      author: { "@id": `${personal.website}/#person` },
    },
    {
      "@type": "CreativeWork",
      "@id": `${personal.website}/#startup-msk-flat-parser`,
      name: "MSK Flat Parser",
      description: lang === "ru"
        ? "Парсер недвижимости в Москве"
        : "Moscow real estate parser",
      url: personal.startups.mskFlatParser,
      author: { "@id": `${personal.website}/#person` },
    },
    {
      "@type": "CreativeWork",
      "@id": `${personal.website}/#startup-calendar-clown`,
      name: "Calendar Clown",
      description: lang === "ru"
        ? "Telegram-бот для управления Google Calendar через голос и AI"
        : "Telegram bot for Google Calendar management via voice and AI",
      url: personal.startups.calendarClown,
      author: { "@id": `${personal.website}/#person` },
    },
  ],
};
---

<!doctype html>
<html lang={tr.meta.htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- SEO Meta -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content={personal.name.full[lang]} />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1" />
    <link rel="canonical" href={canonicalURL} />

    <!-- hreflang — для мультиязычного SEO -->
    <link rel="alternate" hreflang="ru" href={ruURL} />
    <link rel="alternate" hreflang="en" href={enURL} />
    <link rel="alternate" hreflang="x-default" href={ruURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="profile" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.site)} />
    <meta property="og:image:alt" content={lang === "ru"
      ? `${personal.name.full.ru} — Fullstack-разработчик`
      : `${personal.name.full.en} — Fullstack Developer`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content={tr.meta.ogLocale} />
    <meta property="og:locale:alternate" content={lang === "ru" ? "en_US" : "ru_RU"} />
    <meta property="og:site_name" content={personal.name.full[lang]} />
    <meta property="profile:first_name" content={personal.name.first[lang]} />
    <meta property="profile:last_name" content={personal.name.last[lang]} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site)} />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <!-- Theme color -->
    <meta name="theme-color" content="#0a0a0b" id="meta-theme-color" />
    <meta name="color-scheme" content="dark light" />

    <!-- Prevent flash of wrong theme -->
    <script is:inline>
      (function() {
        var theme = localStorage.getItem("theme") || "dark";
        if (theme === "light") {
          document.documentElement.classList.add("light");
          var m = document.getElementById("meta-theme-color");
          if (m) m.setAttribute("content", "#f8fafc");
        }
      })();
    </script>

    <!-- IndieWeb: rel="me" для связывания профилей -->
    <link rel="me" href={personal.telegram} />
    <link rel="me" href={personal.github} />

    <!-- Favicons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="msapplication-TileColor" content="#0a0a0b" />

    <!-- Fonts: Inter + JetBrains Mono -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <!-- GEO-оптимизация для нейросетей и поисковиков -->
    <meta name="geo.region" content="RU-MOW" />
    <meta name="geo.placename" content={lang === "ru" ? "Москва" : "Moscow"} />
    <meta name="geo.position" content="55.7558;37.6173" />
    <meta name="ICBM" content="55.7558, 37.6173" />

    <!-- Yandex / Google verification — вставьте реальные ID -->
    <!-- <meta name="yandex-verification" content="XXXXXX" /> -->
    <!-- <meta name="google-site-verification" content="XXXXXX" /> -->
  </head>

  <body class="min-h-screen bg-bg text-text antialiased">
    <a href="#main-content" class="skip-link">{lang === "ru" ? "Перейти к содержимому" : "Skip to content"}</a>
    <slot />

    <!-- Scroll-triggered reveal animations -->
    <script is:inline>
      document.addEventListener("DOMContentLoaded", function () {
        var targets = document.querySelectorAll(".reveal, .stagger-children");
        if (!targets.length) return;
        var observer = new IntersectionObserver(
          function (entries) {
            entries.forEach(function (entry) {
              if (entry.isIntersecting) {
                entry.target.classList.add("visible");
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.1, rootMargin: "0px 0px -60px 0px" }
        );
        targets.forEach(function (el) { observer.observe(el); });
      });
    </script>
  </body>
</html>
