---

<!doctype html>
<html lang={tr.meta.htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- SEO Meta -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content={personal.name.full[lang]} />
    <meta name="creator" content={personal.name.full[lang]} />
    <meta name="publisher" content={personal.name.full[lang]} />
    <meta name="copyright" content={`© 2026 ${personal.name.full[lang]}`} />

    <!-- Robots / индексация -->
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <meta name="googlebot" content="index, follow, max-image-preview:large, max-snippet:-1" />
    <meta name="yandex" content="all" />
    <meta name="bingbot" content="index, follow" />

    <!-- Keywords (всё ещё используются Яндексом) -->
    <meta name="keywords" content={lang === "ru"
      ? "fullstack разработчик, backend разработчик, Node.js, Go, NestJS, Fastify, React, Vue, Next.js, Astro, DevOps, Kubernetes, Docker, микросервисы, Event-Driven Architecture, GraphQL Federation, OpenTelemetry, Kafka, PostgreSQL, pgvector, Redis, gRPC, AI, LLM, RAG, Claude Code, Cursor, ментор, мок-собеседование, карьерная консультация, технический собес, Москва, highload, TypeScript, портфолио, тимлид, Евгений Надточеев, fullstack-разработчик Москва, найм senior разработчика"
      : "fullstack developer, backend engineer, Node.js, Go, NestJS, Fastify, React, Vue, Next.js, Astro, DevOps, Kubernetes, Docker, microservices, Event-Driven, GraphQL Federation, OpenTelemetry, Kafka, PostgreSQL, pgvector, Redis, gRPC, AI, LLM, RAG, Claude Code, Cursor, mentor, mock interview, career consulting, technical interviewer, Moscow, high-load, TypeScript, portfolio, tech lead, Evgeny Nadtocheev, hire senior fullstack developer"} />
    <link rel="canonical" href={canonicalURL} />

    <!-- hreflang - для мультиязычного SEO -->
    <link rel="alternate" hreflang="ru" href={ruURL} />
    <link rel="alternate" hreflang="ru-RU" href={ruURL} />
    <link rel="alternate" hreflang="en" href={enURL} />
    <link rel="alternate" hreflang="en-US" href={enURL} />
    <link rel="alternate" hreflang="x-default" href={ruURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="profile" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.site)} />
    <meta property="og:image:secure_url" content={new URL(ogImage, Astro.site)} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:alt" content={lang === "ru"
      ? `${personal.name.full.ru} - Fullstack-разработчик`
      : `${personal.name.full.en} - Fullstack Developer`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content={tr.meta.ogLocale} />
    <meta property="og:locale:alternate" content={lang === "ru" ? "en_US" : "ru_RU"} />
    <meta property="og:site_name" content={personal.name.full[lang]} />
    <meta property="profile:first_name" content={personal.name.first[lang]} />
    <meta property="profile:last_name" content={personal.name.last[lang]} />
    <meta property="profile:gender" content="male" />
    <meta property="profile:username" content="webappmaster" />
    <meta property="article:author" content={personal.website} />
    <meta property="article:published_time" content="2025-03-12T00:00:00+03:00" />
    <meta property="article:modified_time" content="2026-06-09T00:00:00+03:00" />
    <meta property="og:updated_time" content="2026-06-09T00:00:00+03:00" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site)} />
    <meta name="twitter:image:alt" content={lang === "ru"
      ? `${personal.name.full.ru} - Fullstack-разработчик`
      : `${personal.name.full.en} - Fullstack Developer`} />
    <meta name="twitter:domain" content="nadtocheev.ru" />
    <meta name="twitter:url" content={canonicalURL} />
    <meta name="twitter:label1" content={lang === "ru" ? "Должность" : "Job title"} />
    <meta name="twitter:data1" content={lang === "ru" ? "Fullstack-разработчик" : "Fullstack Developer"} />
    <meta name="twitter:label2" content={lang === "ru" ? "Локация" : "Location"} />
    <meta name="twitter:data2" content={lang === "ru" ? "Москва, удалённо" : "Moscow, remote"} />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <!-- Theme color -->
    <meta name="theme-color" content="#0a0a0b" id="meta-theme-color" />
    <meta name="color-scheme" content="dark light" />

    <!-- PWA + Apple Web App + Windows tiles -->
    <meta name="application-name" content={personal.name.full[lang]} />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content={personal.name.last[lang]} />
    <meta name="format-detection" content="telephone=yes, email=yes, address=no" />
    <meta name="HandheldFriendly" content="True" />
    <meta name="MobileOptimized" content="320" />
    <meta name="msapplication-TileImage" content="/favicon-512.png" />
    <meta name="msapplication-config" content="/browserconfig.xml" />
    <meta name="msapplication-tap-highlight" content="no" />

    <!-- Prevent flash of wrong theme -->
    <script is:inline>
      (function() {
        var theme = localStorage.getItem("theme") || "dark";
        if (theme === "light") {
          document.documentElement.classList.add("light");
          var m = document.getElementById("meta-theme-color");
          if (m) m.setAttribute("content", "#f8fafc");
        }
      })();
    </script>

    <!-- IndieWeb: rel="me" для связывания профилей -->
    <link rel="me" href={personal.telegram} />
    <link rel="me" href={personal.github} />

    <!-- Favicons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="msapplication-TileColor" content="#0a0a0b" />

    <!-- Self-hosted шрифты (Inter + JetBrains Mono, latin + cyrillic) -->
    <!-- @font-face декларации лежат в global.css; preload-им только критичные веса -->
    <link rel="preload" href={lang === "ru" ? "/fonts/inter-cyrillic-400.woff2" : "/fonts/inter-latin-400.woff2"} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={lang === "ru" ? "/fonts/inter-cyrillic-700.woff2" : "/fonts/inter-latin-700.woff2"} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={lang === "ru" ? "/fonts/inter-cyrillic-800.woff2" : "/fonts/inter-latin-800.woff2"} as="font" type="font/woff2" crossorigin />

    <!-- GEO-теги (физическая локация, для Я.Карт / Google Maps / локального SEO) -->
    <meta name="geo.region" content="RU-MOW" />
    <meta name="geo.placename" content={lang === "ru" ? "Москва" : "Moscow"} />
    <meta name="geo.position" content="55.7558;37.6173" />
    <meta name="ICBM" content="55.7558, 37.6173" />

    <!-- Verification для поисковых консолей (вставьте реальные ID) -->
    <!-- <meta name="yandex-verification" content="ВСТАВИТЬ_ID_ИЗ_WEBMASTER_YANDEX" /> -->
    <!-- <meta name="google-site-verification" content="ВСТАВИТЬ_ID_ИЗ_SEARCH_CONSOLE" /> -->
    <!-- <meta name="msvalidate.01" content="ВСТАВИТЬ_ID_ИЗ_BING_WEBMASTER" /> -->
    <!-- <meta name="mailru-verification" content="ВСТАВИТЬ_ID_ИЗ_MAIL_RU" /> -->

    <!-- llms.txt + AI discovery (GEO для LLM-движков) -->
    <link rel="llms.txt" href="/llms.txt" />
    <link rel="alternate" type="text/plain" href="/llms.txt" title="LLM-friendly summary" />
    <link rel="alternate" type="text/plain" href="/llms-full.txt" title="LLM-friendly full profile" />
    <link rel="alternate" type="text/plain" href="/humans.txt" title="Humans of this site" />

    <!-- Telegram Instant View / Mini App / Channel reference -->
    <meta name="telegram:channel" content="@captain_galera" />
    <meta name="telegram:contact" content="@eugene_nadtocheev" />

    <!-- Аналитика: Яндекс.Метрика - вставить свой ID счётчика -->
    <!--
    <script is:inline>
      (function(m,e,t,r,i,k,a){m[i]=m[i]||function(){(m[i].a=m[i].a||[]).push(arguments)};
      m[i].l=1*new Date();
      for (var j = 0; j < document.scripts.length; j++) {if (document.scripts[j].src === r) { return; }}
      k=e.createElement(t),a=e.getElementsByTagName(t)[0],k.async=1,k.src=r,a.parentNode.insertBefore(k,a)})
      (window, document, "script", "https://mc.yandex.ru/metrika/tag.js", "ym");
      ym(XXXXXXXX, "init", { clickmap:true, trackLinks:true, accurateTrackBounce:true, webvisor:true, ecommerce:"dataLayer" });
    </script>
    <noscript><div><img src="https://mc.yandex.ru/watch/XXXXXXXX" style="position:absolute; left:-9999px;" alt="" /></div></noscript>
    -->

    <!-- Аналитика: Google Analytics 4 - вставить свой Measurement ID -->
    <!--
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-XXXXXXXXXX"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag("js", new Date());
      gtag("config", "G-XXXXXXXXXX", { anonymize_ip: true });
    </script>
    -->
  </head>

  <body class="min-h-screen bg-bg text-text antialiased">
    <a href="#main-content" class="skip-link">{tr.a11y.skipToContent}</a>
    <div id="scroll-progress" aria-hidden="true"></div>
    <slot />

    <!-- Scroll-triggered reveal animations -->
    <script is:inline>
      document.addEventListener("DOMContentLoaded", function () {
        var targets = document.querySelectorAll(".reveal, .stagger-children");
        if (!targets.length) return;
        var observer = new IntersectionObserver(
          function (entries) {
            entries.forEach(function (entry) {
              if (entry.isIntersecting) {
                entry.target.classList.add("visible");
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.1, rootMargin: "0px 0px -60px 0px" }
        );
        targets.forEach(function (el) { observer.observe(el); });
      });
    </script>

    <!-- Scroll progress bar -->
    <script is:inline>
      (function () {
        if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;
        var bar = document.getElementById("scroll-progress");
        if (!bar) return;
        window.addEventListener("scroll", function () {
          var scrollTop = window.scrollY;
          var docHeight = document.documentElement.scrollHeight - window.innerHeight;
          if (docHeight > 0) {
            bar.style.width = (scrollTop / docHeight * 100) + "%";
          }
        }, { passive: true });
      })();
    </script>

    <!-- Button ripple effect -->
    <script is:inline>
      (function () {
        if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;
        document.addEventListener("click", function (e) {
          var btn = e.target.closest(".btn-ripple");
          if (!btn) return;
          var rect = btn.getBoundingClientRect();
          var ripple = document.createElement("span");
          ripple.className = "ripple";
          ripple.style.left = (e.clientX - rect.left) + "px";
          ripple.style.top = (e.clientY - rect.top) + "px";
          btn.appendChild(ripple);
          ripple.addEventListener("animationend", function () {
            ripple.remove();
          });
        });
      })();
    </script>

    <!-- Section anchor links + back-to-top -->
    <button id="back-to-top" class="back-to-top" type="button" aria-label={lang === "ru" ? "Наверх" : "Back to top"} title={lang === "ru" ? "Наверх" : "Back to top"}>
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M12 19V5" />
        <path d="M5 12l7-7 7 7" />
      </svg>
    </button>

    <script is:inline define:vars={{ anchorAria: lang === "ru" ? "Скопировать ссылку на раздел" : "Copy link to section" }}>
      document.addEventListener("DOMContentLoaded", function () {
        /* Section anchor # buttons */
        document.querySelectorAll("section[id]").forEach(function (section) {
          var id = section.id;
          if (!id || id === "hero") return;
          var h2 = section.querySelector("h2.section-title");
          if (!h2 || h2.querySelector(".section-anchor")) return;
          var a = document.createElement("a");
          a.href = "#" + id;
          a.className = "section-anchor";
          a.textContent = "#";
          a.setAttribute("aria-label", anchorAria + ": " + h2.textContent.trim());
          a.addEventListener("click", function (e) {
            if (navigator.clipboard && window.location && window.location.href) {
              var url = window.location.origin + window.location.pathname + "#" + id;
              navigator.clipboard.writeText(url).then(function () {
                a.classList.add("copied");
                setTimeout(function () { a.classList.remove("copied"); }, 1500);
              }).catch(function () {});
            }
          });
          h2.appendChild(a);
        });

        /* Back-to-top button */
        var btn = document.getElementById("back-to-top");
        if (!btn) return;
        var threshold = 600;
        var update = function () {
          if (window.scrollY > threshold) btn.classList.add("visible");
          else btn.classList.remove("visible");
        };
        window.addEventListener("scroll", update, { passive: true });
        update();
        btn.addEventListener("click", function () {
          window.scrollTo({ top: 0, behavior: "smooth" });
        });
      });
    </script>
  </body>
</html>
